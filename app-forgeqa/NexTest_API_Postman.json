            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Get current user profile. Test: expired token, malformed token, 'none' alg, no token, different user's token, token in URL vs header."
          },
          "response": [
            {
              "name": "Success (200)",
              "code": 200,
              "body": "{\n  \"user\": {\n    \"id\": \"6655abc...\",\n    \"email\": \"tester@example.com\",\n    \"createdAt\": \"2025-01-01T00:00:00.000Z\"\n  }\n}"
            }
          ]
        },
        {
          "name": "GET /api/settings/api-keys",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/settings/api-keys",
              "host": ["{{baseUrl}}"],
              "path": ["api", "settings", "api-keys"]
            },
            "description": "List which AI providers have saved keys. Test: IDOR (no user ID in response but verify isolation), information disclosure."
          },
          "response": [
            {
              "name": "Success (200)",
              "code": 200,
              "body": "{\n  \"keys\": {\n    \"gemini\": true,\n    \"openai\": false,\n    \"groq\": false,\n    \"claude\": false,\n    \"openrouter\": false,\n    \"opencode\": false\n  }\n}"
            }
          ]
        },
        {
          "name": "POST /api/settings/api-key",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"gemini\",\n  \"apiKey\": \"AIzaSyTest123456789\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/settings/api-key",
              "host": ["{{baseUrl}}"],
              "path": ["api", "settings", "api-key"]
            },
            "description": "Save encrypted API key. Test: injection in provider/apiKey, overwrite another user's key (IDOR), mass assignment, key logged in plaintext (check server logs)."
          },
          "response": [
            {
              "name": "Success (200)",
              "code": 200,
              "body": "{\n  \"ok\": true\n}"
            },
            {
              "name": "Error (400)",
              "code": 400,
              "body": "{\n  \"error\": \"Provider and API key are required.\"\n}"
            }
          ]
        },
        {
          "name": "DELETE /api/settings/api-key",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/settings/api-key?provider=gemini",
              "host": ["{{baseUrl}}"],
              "path": ["api", "settings", "api-key"],
              "query": [
                { "key": "provider", "value": "gemini" }
              ]
            },
            "description": "Delete saved API key. Test: IDOR by changing provider, delete another user's key access via the provider parameter."
          },
          "response": [
            {
              "name": "Success (200)",
              "code": 200,
              "body": "{\n  \"ok\": true\n}"
            },
            {
              "name": "Error (400)",
              "code": 400,
              "body": "{\n  \"error\": \"Provider query parameter is required.\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Knowledge Base",
      "description": "File and knowledge base management endpoints. Security focus: file upload attacks, path traversal, IDOR, SSRF.",
      "item": [
        {
          "name": "GET /api/knowledge/files",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/knowledge/files?search=test",
              "host": ["{{baseUrl}}"],
              "path": ["api", "knowledge", "files"],
              "query": [
                { "key": "search", "value": "test" }
              ]
            },
            "description": "List uploaded files. Test: NoSQL injection in search param, see other users' files (IDOR), path traversal in search."
          },
          "response": [
            {
              "name": "Success (200)",
              "code": 200,
              "body": "{\n  \"files\": [...],\n  \"storageMode\": \"mongo\"\n}"
            }
          ]
        },
        {
          "name": "POST /api/knowledge/upload",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "type": "file",
                  "src": "",
                  "description": "Upload up to 12 files. Supported: .txt, .pdf, .docx, .png, .jpg, .jpeg, .gif, .webp"
