            "url": {
              "raw": "{{baseUrl}}/api/knowledge/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "knowledge", "upload"]
            },
            "description": "Upload files. Test: path traversal in filename, ZIP bomb, SVG with XSS, very large file (over 25MB), 13+ files, executable upload (.exe, .sh, .php), NoSQL injection in metadata."
          },
          "response": [
            {
              "name": "Success (200)",
              "code": 200,
              "body": "{\n  \"files\": [\n    {\n      \"_id\": \"...\",\n      \"fileName\": \"test.pdf\",\n      \"fileSize\": 12345,\n      \"mimeType\": \"application/pdf\",\n      \"createdAt\": \"...\"\n    }\n  ]\n}"
