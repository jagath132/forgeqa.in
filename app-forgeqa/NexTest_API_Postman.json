              "name": "Success (200)",
              "code": 200,
              "body": "{\n  \"chunks\": [\n    {\n      \"file_name\": \"test.pdf\",\n      \"chunk_text\": \"...\",\n      \"score\": 0.95\n    }\n  ]\n}"
