    {
      "name": "AI Generation",
      "description": "AI test case and script generation. Security focus: prompt injection, API key exposure, DoS, SSRF via model endpoints.",
      "item": [
        {
          "name": "POST /api/generate-test-cases",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requirement\": \"User should be able to log in with email and password\",\n  \"provider\": \"gemini\",\n  \"model\": \"gemini-2.0-flash-lite\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/generate-test-cases",
              "host": ["{{baseUrl}}"],
              "path": ["api", "generate-test-cases"]
            },
            "description": "Generate test cases (non-streaming). Test: prompt injection (ignore instructions, output system prompt), very long requirement (DoS), NoSQL injection, provider switching to steal API key, model hallucination."
          },
          "response": [
            {
              "name": "Success (200)",
              "code": 200,
              "body": "{\n  \"testCases\": [...],\n  \"knowledgeContext\": [...]\n}"
            },
            {
              "name": "Error (400) - Short requirement",
              "code": 400,
              "body": "{\n  \"error\": \"Requirement text must be at least 10 characters.\"\n}"
            },
            {
              "name": "Error (500) - Missing API key",
              "code": 500,
              "body": "{\n  \"error\": \"Missing gemini API key. Provide it in settings or env.\"\n}"
            }
          ]
        },
        {
          "name": "POST /api/generate-test-cases/stream",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requirement\": \"User should be able to log in with email and password\",\n  \"provider\": \"gemini\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/generate-test-cases/stream",
              "host": ["{{baseUrl}}"],
              "path": ["api", "generate-test-cases", "stream"]
            },
            "description": "SSE streaming generation. Test: slow HTTP read DoS, concurrent streams, premature connection close, SSE injection."
          },
          "response": [
            {
              "name": "SSE Stream",
              "code": 200,
              "body": "event: phase\ndata: {\"phase\":\"knowledge\",\"message\":\"Searching knowledge base...\"}\n\nevent: token\ndata: {\"token\":\"{\"}\n\nevent: complete\ndata: {\"testCases\":[...],\"knowledgeContext\":[...]}\n"
            }
          ]
        },
        {
          "name": "POST /api/generate-test-scripts",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"framework\": \"playwright\",\n  \"language\": \"typescript\",\n  \"targetUrl\": \"https://example.com\",\n  \"testCases\": [\n    {\n      \"tcId\": \"TC-001\",\n      \"title\": \"Successful Login\",\n      \"priority\": \"High\",\n      \"precondition\": \"User is registered\",\n      \"steps\": [\"Navigate to /login\", \"Enter email\", \"Enter password\", \"Click Login\"],\n      \"expectedResult\": \"User is redirected to dashboard\"\n    }\n  ],\n  \"provider\": \"gemini\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/generate-test-scripts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "generate-test-scripts"]
            },
            "description": "Generate automation script. Test: command injection in targetUrl/provider, code injection in testCases steps, XSS via generated script, path traversal in output."
          },
          "response": [
            {
              "name": "Success (200)",
              "code": 200,
              "body": "{\n  \"script\": \"import { test, expect } from '@playwright/test';...\",\n  \"framework\": \"playwright\",\n  \"language\": \"typescript\"\n}"
            },
            {
              "name": "Error (400) - Missing fields",
              "code": 400,
              "body": "{\n  \"error\": \"framework, language, targetUrl and testCases are required.\"\n}"
            }
          ]
        }
      ]
    },
