                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/knowledge/chunks/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "knowledge", "chunks", "refresh"]
            },
            "description": "Re-process all chunkable files into text chunks. Test: DoS by calling repeatedly, resource exhaustion."
          },
          "response": [
            {
              "name": "Success (200)",
              "code": 200,
              "body": "{\n  \"processed\": 5,\n  \"failed\": 0\n}"
            }
          ]
        }
      ]
